# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Google OAuth ────────────────────────────────────────────────────────────
# Get these from: https://console.cloud.google.com/
# Create a project → Enable Gmail API → OAuth 2.0 Client ID (Web application)
# Add http://localhost:8000/auth/callback as Authorized redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ── Notion (opcional) ───────────────────────────────────────────────────────
# Get from: https://www.notion.so/my-integrations
# Create integration → share your DB with it → copy the database ID from the URL
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=your-database-id

# ── App config ──────────────────────────────────────────────────────────────
SECRET_KEY=cambia-esto-en-produccion
POLL_INTERVAL_SECONDS=60
